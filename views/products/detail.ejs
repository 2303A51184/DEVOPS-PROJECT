<%- include('../partials/header') %>

<div class="container product-detail-page">
  <!-- Product Main Section -->
  <div class="product-main">
    <!-- Image Gallery -->
    <div class="product-gallery">
      <div class="gallery-thumbs">
        <% product.images.forEach((img, i) => { %>
          <img src="/images/uploads/<%= img %>" alt="thumb-<%= i %>"
               class="thumb <%= i===0?'active':'' %>" onclick="setMainImage(this.src)" />
        <% }) %>
      </div>
      <div class="gallery-main">
        <img src="/images/uploads/<%= product.images[0] %>" alt="<%= product.name %>" id="mainImage" />
      </div>
    </div>

    <!-- Product Info -->
    <div class="product-info">
      <p class="product-brand"><%= product.brand %></p>
      <h1 class="product-name"><%= product.name %></h1>

      <div class="product-rating">
        <% for(let i=1;i<=5;i++) { %>
          <i class="fas fa-star <%= i <= Math.round(product.averageRating) ? 'active' : '' %>"></i>
        <% } %>
        <span><%= product.averageRating %> (<%= product.numReviews %> reviews)</span>
      </div>

      <div class="product-price-section">
        <% if (product.discount > 0) { %>
          <span class="price-big">₹<%= (product.price - (product.price * product.discount / 100)).toFixed(0) %></span>
          <span class="price-strike">₹<%= product.price %></span>
          <span class="badge-discount"><%= product.discount %>% off</span>
        <% } else { %>
          <span class="price-big">₹<%= product.price %></span>
        <% } %>
      </div>

      <div class="stock-info">
        <% if (product.stock > 10) { %>
          <span class="in-stock"><i class="fas fa-check-circle"></i> In Stock</span>
        <% } else if (product.stock > 0) { %>
          <span class="low-stock"><i class="fas fa-exclamation-circle"></i> Only <%= product.stock %> left!</span>
        <% } else { %>
          <span class="out-stock"><i class="fas fa-times-circle"></i> Out of Stock</span>
        <% } %>
      </div>

      <div class="product-description">
        <h3>Description</h3>
        <p><%= product.description %></p>
      </div>

      <% if (product.stock > 0) { %>
        <div class="product-actions">
          <form action="/cart/add" method="POST" class="action-form">
            <input type="hidden" name="productId" value="<%= product._id %>" />
            <div class="qty-selector">
              <label>Qty:</label>
              <select name="quantity">
                <% for(let i=1; i<=Math.min(product.stock, 10); i++) { %>
                  <option value="<%= i %>"><%= i %></option>
                <% } %>
              </select>
            </div>
            <button type="submit" class="btn btn-primary btn-lg"><i class="fas fa-cart-plus"></i> Add to Cart</button>
          </form>
          <form action="/wishlist/toggle" method="POST">
            <input type="hidden" name="productId" value="<%= product._id %>" />
            <button type="submit" class="btn btn-outline btn-lg"><i class="fas fa-heart"></i> Wishlist</button>
          </form>
        </div>
      <% } %>

      <div class="product-meta">
        <p><strong>Category:</strong> <%= product.category %> <% if(product.subcategory) { %>/ <%= product.subcategory %><% } %></p>
        <p><strong>Seller:</strong> <%= product.seller ? product.seller.name : 'ShopNow' %></p>
        <% if (product.tags && product.tags.length > 0) { %>
          <p><strong>Tags:</strong> <%= product.tags.join(', ') %></p>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Reviews Section -->
  <div class="reviews-section">
    <h2>Customer Reviews</h2>

    <!-- Add Review -->
    <% if (currentUser && currentUser.role === 'customer') { %>
      <div class="review-form-box">
        <h3>Write a Review</h3>
        <form action="/products/<%= product._id %>/review" method="POST">
          <div class="star-picker" id="starPicker">
            <% for(let i=1;i<=5;i++) { %>
              <i class="fas fa-star" data-val="<%= i %>"></i>
            <% } %>
          </div>
          <input type="hidden" name="rating" id="ratingInput" value="5" required />
          <textarea name="comment" rows="3" placeholder="Share your experience with this product..." required></textarea>
          <button type="submit" class="btn btn-primary">Submit Review</button>
        </form>
      </div>
    <% } %>

    <!-- Display Reviews -->
    <% if (product.reviews.length === 0) { %>
      <p class="no-reviews">No reviews yet. Be the first to review!</p>
    <% } else { %>
      <div class="reviews-list">
        <% product.reviews.forEach(review => { %>
          <div class="review-card">
            <div class="review-header">
              <img src="/images/uploads/<%= review.user && review.user.avatar ? review.user.avatar : 'default-avatar.png' %>" alt="user" class="review-avatar" />
              <div>
                <strong><%= review.name %></strong>
                <div class="review-stars">
                  <% for(let i=1;i<=5;i++) { %>
                    <i class="fas fa-star <%= i <= review.rating ? 'active' : '' %>"></i>
                  <% } %>
                </div>
                <small><%= new Date(review.createdAt).toLocaleDateString('en-IN') %></small>
              </div>
              <% if (currentUser && (currentUser.role === 'admin' || (currentUser._id && currentUser._id.toString() === review.user._id.toString()))) { %>
                <form action="/products/<%= product._id %>/review/<%= review._id %>?_method=DELETE" method="POST" style="margin-left:auto">
                  <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                </form>
              <% } %>
            </div>
            <p class="review-comment"><%= review.comment %></p>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <!-- Related Products -->
  <% if (related.length > 0) { %>
    <div class="related-section">
      <h2>Related Products</h2>
      <div class="products-grid">
        <% related.forEach(p => { %>
          <%- include('../partials/product-card', { product: p }) %>
        <% }) %>
      </div>
    </div>
  <% } %>
</div>

<script>
function setMainImage(src) {
  document.getElementById('mainImage').src = src;
  document.querySelectorAll('.thumb').forEach(t => t.classList.remove('active'));
  event.target.classList.add('active');
}

// Star picker
const stars = document.querySelectorAll('#starPicker .fa-star');
const ratingInput = document.getElementById('ratingInput');
if (stars.length) {
  stars.forEach((star, i) => {
    star.addEventListener('click', () => {
      ratingInput.value = i + 1;
      stars.forEach((s, j) => s.classList.toggle('active', j <= i));
    });
    star.addEventListener('mouseover', () => stars.forEach((s, j) => s.classList.toggle('hover', j <= i)));
    star.addEventListener('mouseout', () => stars.forEach(s => s.classList.remove('hover')));
  });
  // Default highlight
  stars.forEach((s, j) => s.classList.toggle('active', j < 5));
}
</script>

<%- include('../partials/footer') %>
