<%- include('../partials/header') %>

<div class="container listing-page">
  <!-- Filters Sidebar -->
  <aside class="filters-sidebar">
    <h3>Filters</h3>
    <form action="/products" method="GET" id="filterForm">
      <input type="hidden" name="search" value="<%= query.search || '' %>" />

      <div class="filter-group">
        <h4>Category</h4>
        <% categories.forEach(cat => { %>
          <label>
            <input type="radio" name="category" value="<%= cat %>" <%= query.category === cat ? 'checked' : '' %> onchange="this.form.submit()" />
            <%= cat %>
          </label>
        <% }) %>
        <label>
          <input type="radio" name="category" value="" <%= !query.category ? 'checked' : '' %> onchange="this.form.submit()" /> All
        </label>
      </div>

      <div class="filter-group">
        <h4>Price Range</h4>
        <div class="price-inputs">
          <input type="number" name="minPrice" placeholder="Min ₹" value="<%= query.minPrice || '' %>" />
          <span>—</span>
          <input type="number" name="maxPrice" placeholder="Max ₹" value="<%= query.maxPrice || '' %>" />
        </div>
        <button type="submit" class="btn btn-sm">Apply</button>
      </div>

      <div class="filter-group">
        <h4>Minimum Rating</h4>
        <% [4,3,2,1].forEach(r => { %>
          <label>
            <input type="radio" name="rating" value="<%= r %>" <%= query.rating == r ? 'checked' : '' %> onchange="this.form.submit()" />
            <% for(let i=1;i<=5;i++) { %><i class="fas fa-star <%= i<=r?'active':'' %>"></i><% } %> & above
          </label>
        <% }) %>
      </div>
    </form>
  </aside>

  <!-- Products Area -->
  <div class="products-area">
    <div class="listing-header">
      <p class="result-count"><%= total %> results <% if(query.search) { %> for "<strong><%= query.search %></strong>"<% } %></p>
      <div class="sort-bar">
        <span>Sort by:</span>
        <% const sorts = [['newest','Newest'],['price_asc','Price: Low to High'],['price_desc','Price: High to Low'],['rating','Rating']]; %>
        <% sorts.forEach(([val, label]) => { %>
          <a href="/products?<%= new URLSearchParams({...query, sort: val}).toString() %>"
             class="sort-btn <%= query.sort === val ? 'active' : '' %>"><%= label %></a>
        <% }) %>
      </div>
    </div>

    <% if (products.length === 0) { %>
      <div class="empty-state">
        <i class="fas fa-search fa-3x"></i>
        <h3>No products found</h3>
        <p>Try adjusting your filters or search term.</p>
        <a href="/products" class="btn btn-primary">Clear Filters</a>
      </div>
    <% } else { %>
      <div class="products-grid">
        <% products.forEach(p => { %>
          <%- include('../partials/product-card', { product: p }) %>
        <% }) %>
      </div>

      <!-- Pagination -->
      <% if (totalPages > 1) { %>
        <div class="pagination">
          <% if (currentPage > 1) { %>
            <a href="/products?<%= new URLSearchParams({...query, page: currentPage-1}).toString() %>" class="page-btn">← Prev</a>
          <% } %>
          <% for(let i = 1; i <= totalPages; i++) { %>
            <a href="/products?<%= new URLSearchParams({...query, page: i}).toString() %>"
               class="page-btn <%= i === currentPage ? 'active' : '' %>"><%= i %></a>
          <% } %>
          <% if (currentPage < totalPages) { %>
            <a href="/products?<%= new URLSearchParams({...query, page: currentPage+1}).toString() %>" class="page-btn">Next →</a>
          <% } %>
        </div>
      <% } %>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
