<%- include('../partials/header') %>
<div class="container">
  <div class="page-header">
    <h2>My Products</h2>
    <a href="/seller/products/new" class="btn btn-primary"><i class="fas fa-plus"></i> Add Product</a>
  </div>

  <% if (products.length === 0) { %>
    <div class="empty-state">
      <i class="fas fa-box-open fa-3x"></i>
      <h3>No products yet</h3>
      <a href="/seller/products/new" class="btn btn-primary">Add Your First Product</a>
    </div>
  <% } else { %>
    <div class="table-wrapper">
      <table class="data-table">
        <thead>
          <tr><th>Image</th><th>Name</th><th>Price</th><th>Stock</th><th>Category</th><th>Rating</th><th>Actions</th></tr>
        </thead>
        <tbody>
          <% products.forEach(p => { %>
            <tr>
              <td><img src="/images/uploads/<%= p.images[0] %>" width="60" height="60" style="object-fit:cover;border-radius:6px" /></td>
              <td><%= p.name %></td>
              <td>₹<%= p.price %></td>
              <td><span class="<%= p.stock < 5 ? 'text-danger' : '' %>"><%= p.stock %></span></td>
              <td><%= p.category %></td>
              <td><%= p.averageRating %> ⭐ (<%= p.numReviews %>)</td>
              <td class="actions-cell">
                <a href="/seller/products/<%= p._id %>/edit" class="btn btn-sm btn-outline">Edit</a>
                <form action="/seller/products/<%= p._id %>?_method=DELETE" method="POST" style="display:inline">
                  <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this product?')">Delete</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>
<%- include('../partials/footer') %>
