<%- include('../partials/header') %>
<div class="container admin-page">
  <div class="page-header">
    <h2><i class="fas fa-shopping-bag"></i> All Orders</h2>
    <a href="/admin/dashboard" class="btn btn-outline btn-sm">← Dashboard</a>
  </div>

  <div class="table-wrapper">
    <table class="data-table">
      <thead>
        <tr><th>Invoice</th><th>Customer</th><th>Items</th><th>Total</th><th>Payment</th><th>Status</th><th>Date</th><th>Update Status</th></tr>
      </thead>
      <tbody>
        <% orders.forEach(order => { %>
          <tr>
            <td><%= order.invoiceId %></td>
            <td>
              <% if (order.user) { %>
                <strong><%= order.user.name %></strong><br/>
                <small><%= order.user.email %></small>
              <% } else { %>N/A<% } %>
            </td>
            <td><%= order.items.length %></td>
            <td>₹<%= order.total.toFixed(2) %></td>
            <td><%= order.paymentMethod %> — <%= order.paymentStatus %></td>
            <td><span class="status-badge status-<%= order.orderStatus.toLowerCase() %>"><%= order.orderStatus %></span></td>
            <td><%= new Date(order.createdAt).toLocaleDateString('en-IN') %></td>
            <td>
              <form action="/admin/orders/<%= order._id %>/status" method="POST" style="display:flex;gap:0.5rem;align-items:center">
                <select name="status" class="role-select">
                  <% ['Pending','Confirmed','Shipped','Delivered','Cancelled'].forEach(s => { %>
                    <option value="<%= s %>" <%= order.orderStatus === s ? 'selected' : '' %>><%= s %></option>
                  <% }) %>
                </select>
                <button type="submit" class="btn btn-primary btn-sm">Update</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<%- include('../partials/footer') %>
