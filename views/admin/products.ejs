<%- include('../partials/header') %>
<div class="container admin-page">
  <div class="page-header">
    <h2><i class="fas fa-box"></i> All Products</h2>
    <a href="/admin/dashboard" class="btn btn-outline btn-sm">← Dashboard</a>
  </div>

  <div class="table-wrapper">
    <table class="data-table">
      <thead>
        <tr><th>Image</th><th>Name</th><th>Brand</th><th>Category</th><th>Price</th><th>Stock</th><th>Seller</th><th>Rating</th><th>Action</th></tr>
      </thead>
      <tbody>
        <% products.forEach(p => { %>
          <tr>
            <td><img src="/images/uploads/<%= p.images[0] %>" width="55" height="55" style="object-fit:cover;border-radius:6px" /></td>
            <td><%= p.name.substring(0,40) %>...</td>
            <td><%= p.brand %></td>
            <td><%= p.category %></td>
            <td>₹<%= p.price %></td>
            <td class="<%= p.stock < 5 ? 'text-danger' : '' %>"><%= p.stock %></td>
            <td><%= p.seller ? p.seller.name : 'N/A' %></td>
            <td><%= p.averageRating %> ⭐</td>
            <td>
              <form action="/admin/products/<%= p._id %>?_method=DELETE" method="POST">
                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this product?')">Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<%- include('../partials/footer') %>
