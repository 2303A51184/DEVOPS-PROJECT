<%- include('../partials/header') %>
<div class="container wishlist-page">
  <h2><i class="fas fa-heart"></i> My Wishlist</h2>

  <% if (wishlist.length === 0) { %>
    <div class="empty-state">
      <i class="fas fa-heart-broken fa-3x"></i>
      <h3>Your wishlist is empty</h3>
      <p>Save items you love for later!</p>
      <a href="/products" class="btn btn-primary">Browse Products</a>
    </div>
  <% } else { %>
    <div class="wishlist-grid">
      <% wishlist.forEach(product => { %>
        <div class="wishlist-card">
          <a href="/products/<%= product._id %>">
            <img src="/images/uploads/<%= product.images[0] %>" alt="<%= product.name %>" />
          </a>
          <div class="wishlist-card-body">
            <a href="/products/<%= product._id %>"><h3><%= product.name.substring(0,50) %>...</h3></a>
            <p class="wishlist-brand"><%= product.brand %></p>
            <div class="wishlist-price">
              <% if (product.discount > 0) { %>
                <span class="price-current">₹<%= (product.price - product.price * product.discount / 100).toFixed(0) %></span>
                <span class="price-original">₹<%= product.price %></span>
              <% } else { %>
                <span class="price-current">₹<%= product.price %></span>
              <% } %>
            </div>
            <div class="wishlist-actions">
              <form action="/wishlist/move-to-cart" method="POST">
                <input type="hidden" name="productId" value="<%= product._id %>" />
                <button type="submit" class="btn btn-primary btn-sm"><i class="fas fa-cart-plus"></i> Move to Cart</button>
              </form>
              <form action="/wishlist/toggle" method="POST">
                <input type="hidden" name="productId" value="<%= product._id %>" />
                <button type="submit" class="btn btn-danger btn-sm"><i class="fas fa-trash"></i> Remove</button>
              </form>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
<%- include('../partials/footer') %>
