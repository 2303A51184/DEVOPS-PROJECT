<%- include('../partials/header') %>
<div class="container cart-page">
  <h2>Shopping Cart</h2>

  <% if (!cart || cart.items.length === 0) { %>
    <div class="empty-state">
      <i class="fas fa-shopping-cart fa-3x"></i>
      <h3>Your cart is empty</h3>
      <p>Looks like you haven't added anything yet.</p>
      <a href="/products" class="btn btn-primary">Start Shopping</a>
    </div>
  <% } else { %>
    <div class="cart-layout">
      <!-- Cart Items -->
      <div class="cart-items">
        <% cart.items.forEach(item => { %>
          <% if (item.product) { %>
            <div class="cart-item">
              <a href="/products/<%= item.product._id %>">
                <img src="/images/uploads/<%= item.product.images[0] %>" alt="<%= item.product.name %>" />
              </a>
              <div class="cart-item-info">
                <a href="/products/<%= item.product._id %>"><h3><%= item.product.name %></h3></a>
                <p class="cart-item-brand"><%= item.product.brand %></p>
                <p class="cart-item-price">₹<%= item.price.toFixed(2) %> each</p>
                <% if (item.product.stock < 5) { %>
                  <p class="low-stock">Only <%= item.product.stock %> left!</p>
                <% } %>
              </div>
              <div class="cart-item-actions">
                <form action="/cart/update" method="POST" class="qty-form">
                  <input type="hidden" name="productId" value="<%= item.product._id %>" />
                  <select name="quantity" onchange="this.form.submit()">
                    <% for(let i=1; i<=Math.min(item.product.stock, 10); i++) { %>
                      <option value="<%= i %>" <%= item.quantity === i ? 'selected' : '' %>><%= i %></option>
                    <% } %>
                  </select>
                </form>
                <span class="cart-item-total">₹<%= (item.price * item.quantity).toFixed(2) %></span>
                <form action="/cart/remove" method="POST">
                  <input type="hidden" name="productId" value="<%= item.product._id %>" />
                  <button type="submit" class="btn-icon-danger"><i class="fas fa-trash"></i></button>
                </form>
              </div>
            </div>
          <% } %>
        <% }) %>

        <div class="cart-actions">
          <form action="/cart/clear" method="POST">
            <button type="submit" class="btn btn-outline btn-sm">Clear Cart</button>
          </form>
          <a href="/products" class="btn btn-outline btn-sm">Continue Shopping</a>
        </div>
      </div>

      <!-- Order Summary -->
      <div class="order-summary">
        <h3>Order Summary</h3>
        <div class="summary-row"><span>Subtotal</span><span>₹<%= cart.subtotal.toFixed(2) %></span></div>
        <div class="summary-row"><span>GST (18%)</span><span>₹<%= cart.tax.toFixed(2) %></span></div>
        <div class="summary-row"><span>Delivery</span><span class="free">FREE</span></div>
        <hr />
        <div class="summary-row total-row"><span>Total</span><span>₹<%= cart.total.toFixed(2) %></span></div>
        <a href="/orders/checkout" class="btn btn-primary btn-full">Proceed to Checkout</a>
        <div class="secure-badge"><i class="fas fa-lock"></i> 100% Secure Checkout</div>
      </div>
    </div>
  <% } %>
</div>
<%- include('../partials/footer') %>
