<%- include('../partials/header') %>
<div class="container orders-page">
  <h2>My Orders</h2>

  <% if (orders.length === 0) { %>
    <div class="empty-state">
      <i class="fas fa-box-open fa-3x"></i>
      <h3>No orders yet</h3>
      <a href="/products" class="btn btn-primary">Start Shopping</a>
    </div>
  <% } else { %>
    <div class="orders-list">
      <% orders.forEach(order => { %>
        <div class="order-card">
          <div class="order-card-header">
            <div>
              <span class="order-id">Order #<%= order.invoiceId %></span>
              <span class="order-date"><%= new Date(order.createdAt).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric'}) %></span>
            </div>
            <div class="order-badges">
              <span class="status-badge status-<%= order.orderStatus.toLowerCase() %>"><%= order.orderStatus %></span>
              <span class="payment-badge"><%= order.paymentMethod %></span>
            </div>
          </div>

          <div class="order-items-preview">
            <% order.items.slice(0,3).forEach(item => { %>
              <div class="order-item-row">
                <img src="/images/uploads/<%= item.image || 'placeholder.png' %>" alt="<%= item.name %>" />
                <div>
                  <p><%= item.name %></p>
                  <small>Qty: <%= item.quantity %> &bull; ₹<%= item.price %></small>
                </div>
              </div>
            <% }) %>
            <% if (order.items.length > 3) { %>
              <p class="more-items">+<%= order.items.length - 3 %> more items</p>
            <% } %>
          </div>

          <div class="order-card-footer">
            <span class="order-total"><strong>Total: ₹<%= order.total.toFixed(2) %></strong></span>
            <a href="/orders/<%= order._id %>" class="btn btn-outline btn-sm">View Details</a>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
<%- include('../partials/footer') %>
