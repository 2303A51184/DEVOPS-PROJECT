<%- include('../partials/header') %>
<div class="container checkout-page">
  <h2>Checkout</h2>

  <div class="checkout-layout">
    <!-- Left: Address + Payment -->
    <div class="checkout-left">

      <!-- Address Section -->
      <div class="checkout-section">
        <h3><span class="step-num">1</span> Delivery Address</h3>
        <% if (user.addresses.length === 0) { %>
          <p class="no-address">No saved addresses. Add one below.</p>
        <% } else { %>
          <div class="address-list">
            <% user.addresses.forEach((addr, i) => { %>
              <label class="address-option">
                <input type="radio" name="addressIndex" value="<%= i %>" form="orderForm" <%= i === 0 ? 'checked' : '' %> />
                <div class="address-card">
                  <strong><%= addr.fullName %></strong> &bull; <%= addr.phone %>
                  <p><%= addr.street %>, <%= addr.city %>, <%= addr.state %> – <%= addr.pincode %></p>
                  <% if (addr.isDefault) { %><span class="badge-default">Default</span><% } %>
                </div>
              </label>
            <% }) %>
          </div>
        <% } %>

        <!-- Add New Address -->
        <details class="add-address-form">
          <summary>+ Add New Address</summary>
          <form action="/orders/checkout/address" method="POST" class="address-form-inner">
            <div class="form-row">
              <div class="form-group">
                <label>Full Name</label>
                <input type="text" name="fullName" required />
              </div>
              <div class="form-group">
                <label>Phone</label>
                <input type="text" name="phone" required />
              </div>
            </div>
            <div class="form-group">
              <label>Street Address</label>
              <input type="text" name="street" required />
            </div>
            <div class="form-row">
              <div class="form-group">
                <label>City</label>
                <input type="text" name="city" required />
              </div>
              <div class="form-group">
                <label>State</label>
                <input type="text" name="state" required />
              </div>
              <div class="form-group">
                <label>Pincode</label>
                <input type="text" name="pincode" required />
              </div>
            </div>
            <button type="submit" class="btn btn-outline">Save Address</button>
          </form>
        </details>
      </div>

      <!-- Payment Section -->
      <div class="checkout-section">
        <h3><span class="step-num">2</span> Payment Method</h3>
        <div class="payment-options">
          <label class="payment-option">
            <input type="radio" name="paymentMethod" value="COD" form="orderForm" checked />
            <div class="payment-card">
              <i class="fas fa-money-bill-wave"></i>
              <div>
                <strong>Cash on Delivery</strong>
                <p>Pay when your order arrives</p>
              </div>
            </div>
          </label>
          <label class="payment-option">
            <input type="radio" name="paymentMethod" value="ONLINE" form="orderForm" id="onlineRadio" />
            <div class="payment-card">
              <i class="fas fa-credit-card"></i>
              <div>
                <strong>Online Payment</strong>
                <p>Credit/Debit Card, UPI, Netbanking</p>
              </div>
            </div>
          </label>
        </div>

        <!-- Simulate online payment result -->
        <div id="simulateSection" style="display:none;" class="simulate-section">
          <p><strong>Simulate Payment Result:</strong></p>
          <label><input type="radio" name="simulatePayment" value="success" form="orderForm" checked /> ✅ Payment Success</label>
          <label><input type="radio" name="simulatePayment" value="failure" form="orderForm" /> ❌ Payment Failure</label>
        </div>
      </div>
    </div>

    <!-- Right: Order Summary -->
    <div class="checkout-right">
      <div class="order-summary">
        <h3>Order Summary</h3>
        <% cart.items.forEach(item => { %>
          <% if (item.product) { %>
            <div class="summary-item">
              <img src="/images/uploads/<%= item.product.images[0] %>" alt="" />
              <div>
                <p><%= item.product.name.substring(0,40) %>...</p>
                <small>Qty: <%= item.quantity %></small>
              </div>
              <span>₹<%= (item.price * item.quantity).toFixed(2) %></span>
            </div>
          <% } %>
        <% }) %>
        <hr/>
        <div class="summary-row"><span>Subtotal</span><span>₹<%= cart.subtotal.toFixed(2) %></span></div>
        <div class="summary-row"><span>GST (18%)</span><span>₹<%= cart.tax.toFixed(2) %></span></div>
        <div class="summary-row"><span>Delivery</span><span class="free">FREE</span></div>
        <hr/>
        <div class="summary-row total-row"><span>Total</span><span>₹<%= cart.total.toFixed(2) %></span></div>

        <form action="/orders/checkout/place-order" method="POST" id="orderForm">
          <button type="submit" class="btn btn-primary btn-full" <%= user.addresses.length === 0 ? 'disabled' : '' %>>
            <i class="fas fa-lock"></i> Place Order
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
document.getElementById('onlineRadio').addEventListener('change', function() {
  document.getElementById('simulateSection').style.display = this.checked ? 'block' : 'none';
});
document.querySelectorAll('input[name="paymentMethod"]').forEach(r => {
  r.addEventListener('change', () => {
    document.getElementById('simulateSection').style.display =
      document.getElementById('onlineRadio').checked ? 'block' : 'none';
  });
});
</script>

<%- include('../partials/footer') %>
