<%- include('../partials/header') %>
<div class="container order-detail-page">
  <div class="order-detail-header">
    <h2>Order Details</h2>
    <a href="/orders" class="btn btn-outline btn-sm">← Back to Orders</a>
  </div>

  <div class="order-detail-grid">
    <!-- Order Info -->
    <div class="detail-section">
      <h3>Order Info</h3>
      <table class="info-table">
        <tr><td>Invoice ID</td><td><strong><%= order.invoiceId %></strong></td></tr>
        <tr><td>Date</td><td><%= new Date(order.createdAt).toLocaleString('en-IN') %></td></tr>
        <tr><td>Payment</td><td><%= order.paymentMethod %> — <span class="payment-status-<%= order.paymentStatus.toLowerCase() %>"><%= order.paymentStatus %></span></td></tr>
        <tr><td>Status</td><td><span class="status-badge status-<%= order.orderStatus.toLowerCase() %>"><%= order.orderStatus %></span></td></tr>
      </table>
    </div>

    <!-- Shipping Address -->
    <div class="detail-section">
      <h3>Delivery Address</h3>
      <div class="address-display">
        <strong><%= order.shippingAddress.fullName %></strong><br/>
        <%= order.shippingAddress.phone %><br/>
        <%= order.shippingAddress.street %><br/>
        <%= order.shippingAddress.city %>, <%= order.shippingAddress.state %> – <%= order.shippingAddress.pincode %>
      </div>
    </div>
  </div>

  <!-- Order Items -->
  <div class="detail-section">
    <h3>Items Ordered</h3>
    <div class="order-items-table">
      <% order.items.forEach(item => { %>
        <div class="order-item-detail">
          <img src="/images/uploads/<%= item.image || 'placeholder.png' %>" alt="<%= item.name %>" />
          <div class="item-detail-info">
            <p><%= item.name %></p>
            <small>Qty: <%= item.quantity %></small>
          </div>
          <span>₹<%= (item.price * item.quantity).toFixed(2) %></span>
        </div>
      <% }) %>
    </div>

    <div class="order-summary-totals">
      <div class="summary-row"><span>Subtotal</span><span>₹<%= order.subtotal.toFixed(2) %></span></div>
      <div class="summary-row"><span>GST (18%)</span><span>₹<%= order.tax.toFixed(2) %></span></div>
      <div class="summary-row"><span>Delivery</span><span>FREE</span></div>
      <hr/>
      <div class="summary-row total-row"><span>Total</span><span>₹<%= order.total.toFixed(2) %></span></div>
    </div>
  </div>

  <!-- Order Timeline -->
  <div class="detail-section">
    <h3>Order Timeline</h3>
    <div class="timeline">
      <% order.statusHistory.forEach(h => { %>
        <div class="timeline-step">
          <div class="timeline-dot"></div>
          <div class="timeline-content">
            <strong><%= h.status %></strong>
            <p><%= h.note %></p>
            <small><%= new Date(h.updatedAt).toLocaleString('en-IN') %></small>
          </div>
        </div>
      <% }) %>
    </div>
  </div>

  <!-- Cancel Button -->
  <% if (['Pending', 'Confirmed'].includes(order.orderStatus)) { %>
    <div class="detail-section">
      <h3>Cancel Order</h3>
      <form action="/orders/<%= order._id %>/cancel" method="POST" class="cancel-form">
        <select name="reason" required>
          <option value="">Select reason...</option>
          <option value="Ordered by mistake">Ordered by mistake</option>
          <option value="Found better price">Found better price</option>
          <option value="Delivery time too long">Delivery time too long</option>
          <option value="Changed my mind">Changed my mind</option>
        </select>
        <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to cancel this order?')">Cancel Order</button>
      </form>
    </div>
  <% } %>
</div>
<%- include('../partials/footer') %>
