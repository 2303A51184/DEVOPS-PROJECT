<div class="product-card">
  <a href="/products/<%= product._id %>" class="card-img-link">
    <img src="/images/uploads/<%= product.images[0] || 'placeholder.png' %>" alt="<%= product.name %>" loading="lazy" />
    <% if (product.discount > 0) { %>
      <span class="discount-badge"><%= product.discount %>% OFF</span>
    <% } %>
  </a>
  <div class="card-body">
    <p class="card-brand"><%= product.brand %></p>
    <a href="/products/<%= product._id %>"><h3 class="card-title"><%= product.name.substring(0, 55) %><%= product.name.length > 55 ? '...' : '' %></h3></a>
    <div class="card-rating">
      <span class="stars">
        <% for(let i=1; i<=5; i++) { %>
          <i class="fas fa-star <%= i <= Math.round(product.averageRating) ? 'active' : '' %>"></i>
        <% } %>
      </span>
      <span class="rating-count">(<%= product.numReviews %>)</span>
    </div>
    <div class="card-price">
      <% if (product.discount > 0) { %>
        <span class="price-current">₹<%= (product.price - (product.price * product.discount / 100)).toFixed(0) %></span>
        <span class="price-original">₹<%= product.price %></span>
      <% } else { %>
        <span class="price-current">₹<%= product.price %></span>
      <% } %>
    </div>
    <div class="card-actions">
      <form action="/cart/add" method="POST">
        <input type="hidden" name="productId" value="<%= product._id %>" />
        <input type="hidden" name="quantity" value="1" />
        <button type="submit" class="btn btn-cart"><i class="fas fa-cart-plus"></i> Add to Cart</button>
      </form>
      <form action="/wishlist/toggle" method="POST">
        <input type="hidden" name="productId" value="<%= product._id %>" />
        <button type="submit" class="btn btn-wish"><i class="fas fa-heart"></i></button>
      </form>
    </div>
  </div>
</div>
